# Copy to .env and fill in. NEVER commit the real .env.
# All values below are placeholders.

# --- wacli engine ---
WACLI_STORE_DIR=/data                     # where wacli keeps wacli.db + session.db (Fly volume mount)
PAIR_PHONE=+15551234567                    # your number in intl format; used for `wacli auth --phone`
WACLI_STALE_SECS=900                       # watchdog: bounce sync if doctor's last_sync_at ages past this
WACLI_CHECK_SECS=300                       # watchdog: how often to check freshness

# --- MCP server ---
MCP_TRANSPORT=http                         # http for remote hosting; stdio for local
MCP_HOST=0.0.0.0
MCP_PORT=8081
MCP_AUTH_TOKEN=                            # `openssl rand -hex 32` — static bearer for Claude Code/Desktop
MCP_RESOURCE_URL=https://your-app.fly.dev/mcp   # public URL of this server's /mcp endpoint

# --- OAuth (WorkOS AuthKit) — enables claude.ai + ChatGPT connectors ---
AUTHKIT_DOMAIN=https://your-env.authkit.app     # AuthKit domain (WorkOS dashboard > Domains)
MCP_ALLOWED_EMAILS=you@example.com         # comma-separated allowlist; only these accounts may connect
